{
  "name": "personal-finance-app",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:emulators\" \"npm run dev:client\"",
    "dev:emulators": "firebase emulators:start --only auth,firestore,functions,hosting --import=./dev-data --export-on-exit=./dev-data",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "deploy": "firebase deploy",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "seed": "cd scripts && npm run seed",
    "clear": "cd scripts && npm run clear",
    "test:rules": "cd tests/rules && npm test",
    "test:client": "cd client && npm test",
    "test:all": "npm run test:client && npm run test:rules",
    "_phase1:dev:server": "cd server && npm run dev",
    "_phase1:test:unit": "cd server && npm run test:unit",
    "_phase1:test:api": "cd server && npm run test:api",
    "_phase1:electron:dev": "concurrently \"npm run _phase1:dev:server\" \"npm run dev:client\" \"sleep 3 && electron .\""
  },
  "build": {
    "appId": "com.personal-finance.app",
    "productName": "Personal Finance App",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "client/dist",
        "to": "client/dist"
      },
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules/.cache/**"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office;Finance"
    },
    "deb": {
      "depends": [
        "postgresql",
        "postgresql-client"
      ]
    }
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0"
  }
}
