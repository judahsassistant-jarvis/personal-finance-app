rules_version = '2';

// Personal Finance App — Firestore security rules
// 2a scope: private dogfood, authenticated users read/write only their own docs.
// 2b transition: tighten users/{uid} create to a UID allowlist if exposing to public signup.

service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    function ownerOf(userIdField) {
      return authed() && userIdField == request.auth.uid;
    }

    // --- User profile ---
    match /users/{uid} {
      allow read, update: if authed() && request.auth.uid == uid;
      allow create: if authed() && request.auth.uid == uid;
      allow delete: if false;
    }

    // --- User-scoped collections ---
    match /accounts/{id} {
      allow read, update, delete: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
    }

    match /debts/{id} {
      allow read, update, delete: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
    }

    match /card_buckets/{id} {
      allow read, update, delete: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
    }

    match /transactions/{id} {
      allow read, update, delete: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
    }

    match /recurring_bills/{id} {
      allow read, update, delete: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
    }

    match /monthly_budgets/{id} {
      allow read, update, delete: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
    }

    match /debt_config/{id} {
      allow read, update, delete: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
    }

    match /forecast_snapshots/{id} {
      allow read, delete: if ownerOf(resource.data.user_id);
      allow create, update: if ownerOf(request.resource.data.user_id);
    }

    match /audit_log/{id} {
      allow read: if ownerOf(resource.data.user_id);
      allow create: if ownerOf(request.resource.data.user_id);
      allow update, delete: if false;
    }

    // --- System docs (bank holidays cache, written by Cloud Function) ---
    match /system/{docId} {
      allow read: if authed();
      allow write: if false;
    }

    // Deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
