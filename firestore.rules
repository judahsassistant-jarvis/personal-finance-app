rules_version = '2';

// Personal Finance App — Firestore security rules
// 2a scope: private dogfood, authenticated users read/write only their own docs.
// 2b transition: tighten users/{uid} create to a UID allowlist if exposing to public signup.

service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    // Standard ownership check for create.
    function ownedByMe() {
      return authed() && request.resource.data.user_id == request.auth.uid;
    }

    // Update must keep user_id == auth.uid on both existing and incoming state.
    function stillOwnedByMe() {
      return authed()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid;
    }

    // Read/delete need the existing user_id to match.
    function isMine() {
      return authed() && resource.data.user_id == request.auth.uid;
    }

    // --- User profile ---
    match /users/{uid} {
      allow read, update: if authed() && request.auth.uid == uid;
      allow create: if authed() && request.auth.uid == uid;
      allow delete: if false;
    }

    // --- User-scoped collections (standard pattern) ---
    match /accounts/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /debts/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /card_buckets/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /transactions/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /balance_snapshots/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /recurring_bills/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /monthly_budgets/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /debt_config/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /forecast_snapshots/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    // Audit log: append + read own only. No mutation, no deletion.
    match /audit_log/{id} {
      allow read: if isMine();
      allow create: if ownedByMe();
      allow update, delete: if false;
    }

    // --- System docs (bank holidays cache, written by Cloud Function via admin SDK) ---
    match /system/{docId} {
      allow read: if authed();
      allow write: if false;
    }

    // Deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
