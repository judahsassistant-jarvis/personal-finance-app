rules_version = '2';

// Personal Finance App — Firestore security rules
// 2a scope: private dogfood — only allowlisted email addresses can authenticate
//   to Firestore. Any other signed-in Google account is rejected at the rules
//   layer, even though Firebase Auth itself will happily complete sign-in.
// 2b transition: replace email allowlist with tier-based gating once paid
//   signups are live.

service cloud.firestore {
  match /databases/{database}/documents {

    // Email allowlist for 2a dogfood. Edit here when onboarding a second
    // dogfood user. Emulator-created accounts carry the email the test
    // picker was seeded with, so these work in both emulator and prod.
    function allowedEmails() {
      return [
        'judahsassistant@gmail.com',
        'yehuda.levi@outlook.com',
      ];
    }

    function authed() {
      return request.auth != null
        && request.auth.token.email in allowedEmails();
    }

    // Standard ownership check for create.
    function ownedByMe() {
      return authed() && request.resource.data.user_id == request.auth.uid;
    }

    // Update must keep user_id == auth.uid on both existing and incoming state.
    function stillOwnedByMe() {
      return authed()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid;
    }

    // Read/delete need the existing user_id to match.
    function isMine() {
      return authed() && resource.data.user_id == request.auth.uid;
    }

    // --- User profile ---
    match /users/{uid} {
      allow read, update: if authed() && request.auth.uid == uid;
      allow create: if authed() && request.auth.uid == uid;
      allow delete: if false;
    }

    // --- User-scoped collections (standard pattern) ---
    match /accounts/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /debts/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /card_buckets/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /transactions/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /import_batches/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /balance_snapshots/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /recurring_bills/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /monthly_budgets/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /debt_config/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    // User-defined category rules for the Transactions categoriser.
    // Standard ownership pattern.
    match /category_rules/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    match /forecast_snapshots/{id} {
      allow read, delete: if isMine();
      allow create: if ownedByMe();
      allow update: if stillOwnedByMe();
    }

    // Audit log: append + read own only. No mutation, no deletion.
    match /audit_log/{id} {
      allow read: if isMine();
      allow create: if ownedByMe();
      allow update, delete: if false;
    }

    // Notification log: Cloud Functions (admin SDK, rules bypassed) write
    // entries when BT cliff / payment-reminder emails fire. Client may read
    // its own records to show an in-app history; may not write (admin only).
    match /notification_log/{id} {
      allow read: if isMine();
      allow create, update, delete: if false;
    }

    // Mail collection: queue consumed by the firestore-send-email extension
    // (when installed in prod). Admin-only — clients never touch it.
    match /mail/{id} {
      allow read, write: if false;
    }

    // --- System docs (bank holidays cache, written by Cloud Function via admin SDK) ---
    match /system/{docId} {
      allow read: if authed();
      allow write: if false;
    }

    // Deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
